# Supabase (shared Fulnex project) — Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://gqpbgrranwkfvjnyuhlb.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only, used for privileged ops (leads, staff, creating users).
# NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret

# This email auto-becomes 'owner' on first login (bootstrap the first admin)
LAKONOS_OWNER_EMAIL=you@example.com

# Public site URL (used to build PayFast return/notify URLs)
NEXT_PUBLIC_SITE_URL=https://lakonos.vercel.app

# PayFast recurring billing — copy these from your Fulnex PayFast setup.
# PAYFAST_MODE = "sandbox" while testing, "live" for production.
PAYFAST_MODE=sandbox
PAYFAST_MERCHANT_ID=your-merchant-id
PAYFAST_MERCHANT_KEY=your-merchant-key
PAYFAST_PASSPHRASE=your-passphrase
